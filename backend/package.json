{
  "name": "bakery-cms-backend",
  "version": "1.0.0",
  "description": "Backend API for Bakery CMS",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "start:prod": "node dist/index.js",
    "dev": "node --watch server.js",
    "build": "ncc build server.js -o dist",
    "init-db": "node init_db.js",
    "seed-db": "node seed_db.js",
    "prepare-deploy": "node scripts/prepare-deploy.js",
    "migrate:up": "db-migrate up",
    "migrate:down": "db-migrate down",
    "migrate:create": "db-migrate create"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "db-migrate": "^0.11.14",
    "db-migrate-mysql": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "mysql2": "^3.9.7",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.5",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4"
  }
}
